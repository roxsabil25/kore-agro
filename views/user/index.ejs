            "We grow Quality, We harvest Trust."
          </h3>
        </div>
      </div>

      <div class="lg:w-1/2">
        <div class="relative overflow-hidden rounded-3xl shadow-2xl transition-transform duration-500 hover:scale-[1.02]">
          <img src="img/about-image.jpg" alt="About AHREEN SHAMS" class="w-full h-auto object-cover">
          <div class="absolute inset-0 bg-[#005E48]/10"></div>
        </div>
      </div>

    </div>
  </div>
</section>


<section class="bg-[#f7fe9f] py-16 px-6 relative">
    <div class="max-w-7xl mx-auto">
        <div class="text-center mb-10">
            <h2 class="text-4xl font-bold text-gray-800 mb-2">Check Our Products</h2>
            <img src="img/bdividerline.png" alt="divider" class="mx-auto">
        </div>

        <div class="relative flex items-center">
            <button id="prevBtn" class="absolute -left-10 bg-white p-3 rounded-full shadow-lg z-20 hidden lg:block hover:bg-gray-100">◀</button>
            
            <div id="slider" class="flex gap-6 overflow-x-auto snap-x scroll-smooth no-scrollbar w-full">
                 <% products.forEach((product) => { %>
                   <a href="/products/details/<%= product._id %>"></a>
                <div class="min-w-[280px] md:min-w-[300px] bg-white rounded-2xl shadow-lg p-5 snap-center">
                   
                      <img src="<%= product.productsImge %>" class="w-full h-48 object-cover rounded-xl mb-4">
                      </a>
                    <span class="block text-xl font-bold text-gray-800"><%= product.productname %>
                    <a href=" /products/details/<%= product._id %>  "        class="text-green-700 font-bold border-b-2">Read more</a>
                </div>


<% }) %>



               

               
                </div>

            <button id="nextBtn" class="absolute -right-10 bg-white p-3 rounded-full shadow-lg z-20 hidden lg:block hover:bg-gray-100">▶</button>
        </div>
    </div>

    <script>
        const slider = document.getElementById('slider');
        const prevBtn = document.getElementById('prevBtn');
        const nextBtn = document.getElementById('nextBtn');

        // নেক্সট বাটন
        nextBtn.addEventListener('click', () => {
            slider.scrollBy({ left: 320, behavior: 'smooth' }); // কার্ডের উইডথ অনুযায়ী ভ্যালু সেট করা
        });

        // প্রিভিয়াস বাটন
        prevBtn.addEventListener('click', () => {
            slider.scrollBy({ left: -320, behavior: 'smooth' });
        });
    </script>

