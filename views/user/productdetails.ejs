<%- include('./partials/header') %>

<section class="pt-24 pb-14">
  <div class="max-w-7xl mx-auto px-4">
    <div class="grid md:grid-cols-2 gap-10 items-center">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <img src="<%= product.productsImge %>" class="w-full h-[420px] object-cover rounded-xl">
      </div>
      <div>
        <h1 class="text-4xl font-bold mb-4"><%= product.productname %></h1>
        <p class="text-gray-600 leading-relaxed mb-6"><%= product.description %></p>
        <div class="flex gap-4">
          <a href="#" class="bg-green-600 text-white px-8 py-3 rounded-xl hover:bg-green-700 transition">Order Now</a>
          <a href="/" class="border border-gray-300 px-8 py-3 rounded-xl hover:bg-gray-100 transition">Back</a>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="py-14 bg-white">
  <div class="max-w-7xl mx-auto px-4">
    <h2 class="text-3xl font-bold text-center mb-12">MORE IMAGES</h2>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-6">
       <% if(product.galleryImages && product.galleryImages.length > 0) { %>
         <% product.galleryImages.forEach(function(img){ %>
            <div class="bg-gray-50 rounded-2xl overflow-hidden shadow">
               <img src="<%= img %>" class="h-32 w-full object-cover">
            </div>
         <% }); %>
       <% } %>
    </div>
  </div>
</section>

<%- include('./partials/footer') %>