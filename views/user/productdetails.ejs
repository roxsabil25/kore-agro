<%- include('./partials/header', {title: 'Product Details | Family Hub'}) %>

<!-- ================= PRODUCT DETAILS ================= -->
<section class="pt-24 pb-14">
<div class="max-w-7xl mx-auto px-4">

<div class="grid md:grid-cols-2 gap-10 items-center">

<!-- PRODUCT IMAGE -->
<div class="bg-white rounded-2xl shadow-lg p-6">
<img src="<%= product.productsImge %>"
class="w-full h-[420px] object-cover rounded-xl">
</div>

<!-- PRODUCT INFO -->
<div>

<h1 class="text-4xl font-bold mb-4">
<%= product.productname %>
</h1>

<p class="text-gray-600 leading-relaxed mb-6">
<%= product.description %>
</p>

<div class="flex gap-4">

<a href="#"
class="bg-green-600 text-white px-8 py-3 rounded-xl
hover:bg-green-700 transition shadow-lg">
<i class="fa-solid fa-cart-shopping mr-2"></i>
Order Now
</a>

<a href="/"
class="border border-gray-300 px-8 py-3 rounded-xl
hover:bg-gray-100 transition">
Back
</a>

</div>

</div>

</div>

</div>
</section>

<!-- ================= EXTRA PRODUCT IMAGES ================= -->
<section class="py-14 bg-white">
<div class="max-w-7xl mx-auto px-4">

<h2 class="text-3xl font-bold text-center mb-12 tracking-wide">
MORE CATEGORIES
</h2>

<div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-6">

<!-- CARD -->
 <% product.galleryImages.forEach(function(img){ %>
<div class="bg-gray-50 rounded-2xl overflow-hidden shadow
hover:shadow-2xl transition duration-300
hover:-translate-y-2 group cursor-pointer">

<div class="overflow-hidden">
    
<img src="<%= img %>"
class="h-32 w-full object-cover
group-hover:scale-110 transition duration-500">

</div>


</div>
<% }); %>



</div>
</div>
</section>

<!-- ================= RELATED PRODUCTS ================= -->
<section class="bg-white py-14">
<div class="max-w-7xl mx-auto px-4">

<h2 class="text-3xl font-bold text-center mb-10">
Related Products
</h2>

<div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-8">

<% relatedProducts.forEach((item)=>{ %>

<a href="/products/details/<%= item._id %>"
class="bg-white rounded-2xl shadow hover:shadow-2xl
transition hover:-translate-y-2 group">

<div class="overflow-hidden">
<img src="<%= item.productsImge %>"
class="h-44 w-full object-cover
group-hover:scale-110 transition duration-500">
</div>

<h3 class="text-center py-4 font-semibold">
<%= item.productname %>
</h3>

</a>

<% }) %>

</div>

</div>
</section>

<!-- ================= FOOTER (SAME AS HOME) ================= -->

<%- include('./partials/footer') %>