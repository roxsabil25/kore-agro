<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Admin Dashboard</title>

<!-- Tailwind CSS -->
<script src="https://cdn.tailwindcss.com"></script>

<!-- FontAwesome -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body class="bg-gray-100 font-sans">

<!-- ================= NAVBAR ================= -->
<header class="bg-white shadow-md fixed w-full z-50">
  <div class="max-w-7xl mx-auto px-4 flex justify-between items-center h-16">
    <h1 class="text-2xl font-bold text-green-600">Admin Dashboard</h1>
    <div class="flex items-center gap-4">
      <span class="font-medium">Admin</span>
      <a href="/logout" class="text-red-500 hover:text-red-600 flex items-center gap-2">
        <i class="fa-solid fa-right-from-bracket"></i> Logout
      </a>
    </div>
  </div>
</header>

<div class="flex pt-16">

  <!-- ================= SIDEBAR ================= -->
  <aside class="w-64 bg-white shadow-md min-h-screen p-6 hidden md:block">
    <nav class="flex flex-col gap-4">
      <a href="/admin" class="flex items-center gap-2 p-2 hover:bg-green-100 rounded">
        <i class="fa-solid fa-gauge-high"></i> Dashboard
      </a>
      <a href="/admin/products/add" class="flex items-center gap-2 p-2 hover:bg-green-100 rounded">
        <i class="fa-solid fa-box"></i> Add Product
      </a>
      <a href="/admin/products" class="flex items-center gap-2 p-2 hover:bg-green-100 rounded">
        <i class="fa-solid fa-boxes-stacked"></i> All Products
      </a>
      <a href="/admin/orders" class="flex items-center gap-2 p-2 hover:bg-green-100 rounded">
        <i class="fa-solid fa-cart-shopping"></i> Orders
      </a>
      <a href="/admin/users" class="flex items-center gap-2 p-2 hover:bg-green-100 rounded">
        <i class="fa-solid fa-users"></i> Users
      </a>
    </nav>
  </aside>

  <!-- ================= MAIN CONTENT ================= -->
  <main class="flex-1 p-6">
    
    <!-- Add Product Form -->
    <section class="bg-white p-6 rounded-xl shadow mb-6">
      <h2 class="text-xl font-bold mb-4">Add New Product</h2>
      <form action="/admin/products/add" method="POST" enctype="multipart/form-data" class="flex flex-col gap-4">
        <input type="text" name="productname" placeholder="Product Name" class="border rounded p-2 w-full">
        <input type="text" name="price" placeholder="Product Price" class="border rounded p-2 w-full">
        <input type="text" name="category" placeholder="Product Category" class="border rounded p-2 w-full">

        <textarea name="description" placeholder="Product Description" class="border rounded p-2 w-full"></textarea>
        <input type="file" name="productsImge" accept="image/*" class="border rounded p-2">
        <label class="font-medium">Extra Images</label>
        <input type="file" name="galleryImages" accept="image/*" multiple class="border rounded p-2">
        <button type="submit" class="bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700 transition">
          Add Product
        </button>
      </form>
    </section>

    <!-- Product List -->
    <section class="bg-white p-6 rounded-xl shadow">
      <h2 class="text-xl font-bold mb-4">All Products</h2>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Image</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Product Name</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Description</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Gallery</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            <% products.forEach(function(product) { %>
              <tr>
                <td class="px-6 py-4"><img src="<%= product.productsImge %>" class="w-16 h-16 object-cover rounded"></td>
                <td class="px-6 py-4"><%= product.productname %></td>
                <td class="px-6 py-4"><%= product.description %></td>
                <td class="px-6 py-4 flex gap-2">
                  <% product.galleryImages.forEach(function(img){ %>
                    <img src="<%= img %>" class="w-12 h-12 object-cover rounded">
                  <% }) %>
                </td>
                <td class="px-6 py-4 flex gap-2">
                  <a href="/admin/products/edit/<%= product._id %>" class="text-blue-600 hover:underline">Edit</a>
                  <a href="/admin/products/delete/<%= product._id %>" class="text-red-600 hover:underline">Delete</a>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </section>

  </main>
</div>

</body>
</html>